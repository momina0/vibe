# Server environment variables
# Copy this file to .env and fill in your actual API keys
# Both APIs below are FREE — no credit card required.

PORT=3001

# FREE — Get from https://console.groq.com  (sign up, go to API Keys)
GROQ_API_KEY=your_groq_api_key_here

# FREE — Get from https://foursquare.com/developer (sign up, create app, copy API Key)
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# URL of your frontend (for CORS)
CLIENT_URL=http://localhost:5173
